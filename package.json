{
  "name": "sandbox-system",
  "version": "1.0.0",
  "scripts": {
    "sandbox:dev": "bin/entrypoint.dev.sh",
    "prisma:generate": "bash -O extglob -c 'cat prisma/schema/base.prisma prisma/schema/!(base|prisma).prisma > prisma/schema.prisma && npx prisma generate'",
    "prisma:generate#windows": "powershell -Command \"Get-Content prisma/schema/*.prisma | Set-Content prisma/schema.prisma; npx prisma generate\""
  },
  "dependencies": {
    "@prisma-psm/core": "^1.0.66",
    "@prisma-psm/pg": "^1.0.65",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.0",
    "fs-extra": "^11.3.4",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tar": "^7.5.11",
    "unzip": "^0.1.11",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.18.0",
    "@types/socket.io": "^3.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "prisma": "^7.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
